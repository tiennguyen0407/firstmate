# FirstMate Manager — Environment Variables
# Copy file này thành .env.local để chạy local, hoặc set trực tiếp trong AgentBase Runtime.

# ── GreenNode AgentBase ───────────────────────────────────────────
# API key cho GreenNode MaaS (LLM calls)
GREENNODE_API_KEY=

# IAM credentials — tự động inject khi deploy trên AgentBase Runtime
# Cần set thủ công khi chạy local
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=

# IAM credentials riêng cho Memory service (nếu dùng account khác với runtime)
# Để trống để dùng chung GREENNODE_CLIENT_ID/SECRET ở trên
MEMORY_CLIENT_ID=
MEMORY_CLIENT_SECRET=

# AgentBase Memory store ID (tạo trên GreenNode Portal → AgentBase → Memory)
AGENTBASE_MEMORY_ID=memory-0a44476c-2cac-49ef-b3d3-16593400f94a

# URL của Memory Consolidator Agent runtime — cần thiết cho check_memory.sh
MEMORY_AGENT_URL=https://endpoint-4a0794db-3fd9-4fcc-9b4b-1f6331a38ba3.agentbase-runtime.aiplatform.vngcloud.vn

# ── Telegram ──────────────────────────────────────────────────────
# Bot token từ @BotFather
TELEGRAM_BOT_TOKEN=

# Webhook URL của Manager runtime (dùng khi set Telegram webhook cho prod)
# Để trống khi chạy local với polling
WEBHOOK_URL=

# ── App ───────────────────────────────────────────────────────────
PORT=8080
ENV=production

# Bật DEBUG=true để forward message trực tiếp tới SRE, bỏ qua LangGraph
DEBUG=false
