# ── Manager ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=...
PORT=8080
ENV=development

# ── Runner ────────────────────────────────────────────────────
MANAGER_URL=https://your-manager.agentbase.greennode.ai
RUNNER_ID=sre-tien-macbook
SRE_ID=tien@company.com
TELEGRAM_ID=@tien_sre

# ── Gateway log (tsh ssh) ─────────────────────────────────────
GATEWAY_FOLDER=/path/to/local/gateway                # local mirror của nginx gateway configs
GATEWAY_LOGIN=your-username                          # user SSH dùng với tsh (ví dụ: tiennt14)

# Optional — chỉ cần nếu Runner dùng Redis/DB tools
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_ALLOWED_TABLES=orders,payments,refunds
